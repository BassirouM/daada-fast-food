# ─── Build Next.js ───────────────────────────────────────────────────────────
.next/
out/

# ─── Vercel ──────────────────────────────────────────────────────────────────
# On committe project.json (contient projectId + orgId, pas de secrets)
# mais on ignore le cache Vercel
.vercel/cache/
# NE PAS ignorer .vercel/project.json — nécessaire pour le déploiement CI
# Si .vercel est vide, Vercel CLI utilise VERCEL_ORG_ID + VERCEL_PROJECT_ID

# ─── Variables d'environnement (JAMAIS committer) ────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Garder .env.example et .env.local.example trackés

